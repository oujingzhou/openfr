# OpenFR 配置

# ============= 基础配置 =============
OPENFR_PROVIDER=zhipu
OPENFR_MODEL=glm-4.7
OPENFR_TEMPERATURE=0.0
OPENFR_MAX_TOKENS=4096
OPENFR_VERBOSE=true

# ============= 多 Agent 配置 =============
OPENFR_MAX_DEBATE_ROUNDS=1              # 多空辩论轮数（默认 1）
OPENFR_MAX_RISK_DISCUSS_ROUNDS=1        # 风险辩论轮数（默认 1）
OPENFR_MAX_RECUR_LIMIT=100             # LangGraph 递归限制

# ============= 单 Agent 配置 =============
OPENFR_MAX_ITERATIONS=10
OPENFR_ENABLE_PLAN_EXECUTE=true
OPENFR_ENABLE_SELF_VALIDATION=true
OPENFR_ENABLE_LOOP_DETECTION=true
OPENFR_MAX_TOTAL_TOOL_CALLS=14

# ============= 性能配置 =============
OPENFR_ENABLE_PARALLEL_TOOLS=true
OPENFR_ENABLE_PARALLEL_SOURCES=true

# ============= 工具开关（默认全开） =============
OPENFR_ENABLE_STOCK_TOOLS=true
OPENFR_ENABLE_STOCK_HK_TOOLS=true
OPENFR_ENABLE_FUND_TOOLS=true
OPENFR_ENABLE_FUTURES_TOOLS=true
OPENFR_ENABLE_MACRO_TOOLS=true
OPENFR_ENABLE_INDEX_TOOLS=true

# ============ 国产模型 ============

# DeepSeek - 推理能力强、性价比高
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 豆包 (字节跳动火山引擎)
DOUBAO_API_KEY=your_doubao_api_key_here

# DashScope (阿里云灵积) - 通义千问
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 智谱 AI - GLM 系列（默认提供商）
ZHIPU_API_KEY=your_zhipu_api_key_here

# ModelScope (阿里云魔搭社区)
MODELSCOPE_API_KEY=your_modelscope_api_key_here

# Kimi (Moonshot)
KIMI_API_KEY=your_kimi_api_key_here

# 阶跃星辰
STEPFUN_API_KEY=your_stepfun_api_key_here

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key_here

# ============ 海外模型 ============

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic - Claude 系列
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter - 聚合多家模型
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Together AI
TOGETHER_API_KEY=your_together_api_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here

# ============ 本地部署 ============

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ============ 自定义提供商 ============

# 支持 OpenAI 和 Anthropic 两种 API 格式
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_BASE_URL=https://your-custom-api.com
CUSTOM_API_STYLE=openai                 # openai 或 anthropic
